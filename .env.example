# ==========================================
# NG-VMS ENTERPRISE ON-PREM CONFIGURATION
# ==========================================

# --- SYSTEM SETTINGS ---
PORT=5001
NODE_ENV=production
JWT_SECRET=generate_a_secure_random_string_here

# --- DATABASE (REPLICA SET) ---
# For on-prem high availability
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=change_this_to_a_strong_password
MONGODB_URI=mongodb://admin:change_this_to_a_strong_password@mongo:27017/ngvms?authSource=admin&replicaSet=rs0
REDIS_URL=redis://redis:6379

# --- LOCAL OBJECT STORAGE (MINIO) ---
# Enterprise requirement: Use MinIO instead of AWS S3
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=ngvmsadmin
MINIO_SECRET_KEY=change_this_to_a_strong_minio_password
MINIO_BUCKET=ngvms-assets

# --- LOCAL SMTP ---
# For offline email notifications
SMTP_HOST=smtp_relay
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@ng-vms.enterprise

# --- NETWORKING & PROXY ---
# Caddy handles SSL and routing automatically
DOMAIN_NAME=vms.client.com
TLS_EMAIL=admin@client.com
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_SOCKET_URL=/

# --- LICENSE SYSTEM (OFFLINE) ---
# Enterprise signed offline license.vlic
LICENSE_KEY_PATH=./license.vlic
# 32-char secret for verifying the RSA/HMAC signature
LICENSE_SECRET=your-enterprise-signature-secret
SKIP_HW_LOCK=false
DEPLYOMENT_MODE=ON_PREM

# --- AI & AGENT ORCHESTRATION (PYTHON RUNNERS) ---
# Required for the specialized LLM runners specified in the blueprint
PYTHON_PORT=8000
PYTHON_ENV=production

# --- LLM PROVIDERS ---
# Provide at least one for agent functionality
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# --- VECTOR & KNOWLEDGE GRAPH ---
# For long-term memory and relationship mapping
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# --- AI OBSERVABILITY (AETHER EYES) ---
# OTEL endpoint for tracing agent decisions and LLM latency
OTEL_EXPORTER_OTLP_ENDPOINT=http://prometheus:4317
OTEL_SERVICE_NAME=ngvms-ai-runner
