{$DOMAIN_NAME} {
    # Automatic TLS using email from env
    tls {$TLS_EMAIL}

    # Compression
    encode gzip zstd

    # Real Security Headers Hardening
    header {
        Strict-Transport-Security "max-age=31536000;"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    # Health check endpoint for monitoring
    respond /health 200

    # Backend API Proxy
    reverse_proxy /api/* backend:5001 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
    }

    # WebSocket / Socket.IO Proxy
    reverse_proxy /socket.io/* backend:5001 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
    }

    # Next.js static/build assets proxy
    reverse_proxy /_next/* frontend:3000
    reverse_proxy /static/* frontend:3000

    # Catch-all → Frontend Web Application
    reverse_proxy * frontend:3000
}
