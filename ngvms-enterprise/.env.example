# ==============================================================================
#                 NG-VMS ENTERPRISE ON-PREMISE CONFIGURATION
# ==============================================================================
# Instructions:
# 1. Copy this file to '.env' (cp .env.example .env)
# 2. Restrict permissions (chmod 600 .env)
# 3. Setup required license file named 'license_NGS.lic' in this directory.
# 4. Run './install.sh' to trigger deployment.
# ==============================================================================

# ── SYSTEM SETTINGS ───────────────────────────────────────────────────────────
NODE_ENV=production
# Core random secret keys (Automatically generated by install.sh if left empty)
JWT_SECRET=
SESSION_SECRET=
ENCRYPTION_KEY=

# ── DATABASE & CACHING (REPLICA SET) ──────────────────────────────────────────
# Root administrative credentials (Automatically generated by install.sh if left empty)
MONGO_ROOT_USER=ngvms_root
MONGO_ROOT_PASSWORD=
REDIS_PASSWORD=

# ── LOCAL OBJECT STORAGE (MINIO) ──────────────────────────────────────────────
# Offline secure file/image storage configurations
MINIO_ACCESS_KEY=ngvms_minio_admin
# Root password for object storage (Automatically generated by install.sh if left empty)
MINIO_SECRET_KEY=
MINIO_BUCKET=ngvms-assets

# ── OFF-GRID SMTP MAILER ──────────────────────────────────────────────────────
# Setup SMTP credentials here to unlock real-time security alerts/notifications
SMTP_HOST=smtp_relay
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@ng-vms.enterprise

# ── NETWORKING & TLS ──────────────────────────────────────────────────────────
# Point this to your actual on-prem domain name or server IP address
DOMAIN_NAME=vms.client.local
# Notification email used by Caddy to request public Let's Encrypt TLS certificates
TLS_EMAIL=admin@client.local

# API endpoint references (Relative to public domain)
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_SOCKET_URL=/

# ── GRAFANA & OBSERVABILITY ───────────────────────────────────────────────────
# UI management credentials (Automatically generated by install.sh if left empty)
GRAFANA_USER=admin
GRAFANA_PASSWORD=
GRAFANA_URL=http://localhost:3001

# ── OFFLINE ENTERPRISE LICENSING ──────────────────────────────────────────────
# Path to your offline NGS enterprise signature file (must be in root folder)
LICENSE_KEY_PATH=./license_NGS.lic
# Signature salt validation (Provided with your enterprise agreement key)
LICENSE_SECRET=ngs-enterprise-system-validation-signature-key-2026
SKIP_HW_LOCK=false
DEPLOYMENT_MODE=ON_PREM
