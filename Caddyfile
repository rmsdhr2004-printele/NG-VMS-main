:80 {
    # Compression
    encode gzip zstd
    
    # Health check endpoint
    respond /health 200

    # Backend API
    reverse_proxy /api/* backend:5001 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
    }

    # WebSocket / Socket.IO
    reverse_proxy /socket.io/* backend:5001

    # Next.js static/build assets
    reverse_proxy /_next/* frontend:3000
    reverse_proxy /static/* frontend:3000

    # Catch-all → Frontend
    reverse_proxy * frontend:3000
}
